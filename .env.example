# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (for OAuth redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI-compatible provider (optional; tried first when set)
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Google provider (recommended for Gemini-only setup)
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# AI endpoint anti-spam guard
AI_PARSE_COOLDOWN_MS=3000
AI_PARSE_MAX_PER_10_MIN=40
